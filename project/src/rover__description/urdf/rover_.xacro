<joint name="Rígido 2" type="fixed">
  <origin xyz="0.360009 0.49 1.192273" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="body_two_1"/>
</joint>

<joint name="Revolucionar 3" type="continuous">
  <origin xyz="-0.41 0.027322 -0.059" rpy="0 0 0"/>
  <parent link="body_two_1"/>
  <child link="body_three_1"/>
  <axis xyz="0.0 0.0 -1.0"/>
</joint>

<joint name="Revolucionar 16" type="continuous">
  <origin xyz="-0.00327 0.133957 -0.225" rpy="0 0 0"/>
